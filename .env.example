# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=./vibegate.db

# ── Security ──────────────────────────────────────────────────────────────────
# Generate key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# ── Payment chain (modular: algorand | solana | base) ─────────────────────────
CHAIN=algorand

# ── Algorand Testnet ──────────────────────────────────────────────────────────
ALGO_NETWORK=testnet
ALGO_ALGOD_SERVER=https://testnet-api.algonode.cloud
ALGO_ALGOD_PORT=443
ALGO_ALGOD_TOKEN=
ALGO_INDEXER_SERVER=https://testnet-idx.algonode.cloud
ALGO_INDEXER_PORT=443
# 25-word mnemonic for the master/test-agent wallet
# Fund ALGO: https://bank.testnet.algorand.network/
# Fund USDC: https://usdcfaucet.com/ (select Algorand Testnet)
ALGO_MASTER_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12 word13 word14 word15 word16 word17 word18 word19 word20 word21 word22 word23 word24 word25
# USDC on Algorand testnet
ALGO_USDC_ASSET_ID=10458941

# ── x402 protocol ─────────────────────────────────────────────────────────────
X402_VERSION=1
X402_TIMEOUT_SECONDS=60
