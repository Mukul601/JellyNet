# Copy this to .env and fill in values
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3005
DB_PATH=./jellynet.db
ENCRYPTION_KEY=<generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">
CHAIN=algorand
ALGO_NETWORK=testnet
ALGO_ALGOD_SERVER=https://testnet-api.algonode.cloud
ALGO_ALGOD_PORT=443
ALGO_ALGOD_TOKEN=
ALGO_INDEXER_SERVER=https://testnet-idx.algonode.cloud
ALGO_INDEXER_PORT=443
ALGO_USDC_ASSET_ID=10458941
X402_VERSION=1
X402_TIMEOUT_SECONDS=60
NEXTAUTH_SECRET=<same value as frontend NEXTAUTH_SECRET>
GOOGLE_CLIENT_ID=<from Google Cloud Console>
